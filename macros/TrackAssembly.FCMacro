# ── SVG hover-popup tooltip ───────────────────────────────────────────────────

class _SvgTip(QtWidgets.QFrame):
    """Singleton borderless popup rendering a crisp SVG next to a hovered widget."""
    _inst = None

    @classmethod
    def get(cls):
        if cls._inst is None:
            cls._inst = cls(FreeCADGui.getMainWindow())
        return cls._inst

    def __init__(self, parent):
        super().__init__(
            parent,
            QtCore.Qt.ToolTip | QtCore.Qt.FramelessWindowHint |
            QtCore.Qt.NoDropShadowWindowHint
        )
        self.setAttribute(QtCore.Qt.WA_ShowWithoutActivating)
        self.setStyleSheet(
            "QFrame { background:#fffef5; border:1px solid #c8a44a; border-radius:6px; }"
        )
        self._img = QtWidgets.QLabel()
        self._img.setAlignment(QtCore.Qt.AlignCenter)
        self._cap = QtWidgets.QLabel()
        self._cap.setAlignment(QtCore.Qt.AlignCenter)
        self._cap.setStyleSheet(
            "color:#333; font-size:11px; padding:0 6px 4px; border:none;"
        )
        self._cap.setWordWrap(True)
        lay = QtWidgets.QVBoxLayout(self)
        lay.setContentsMargins(6, 6, 6, 4)
        lay.setSpacing(3)
        lay.addWidget(self._img)
        lay.addWidget(self._cap)
        self.hide()

    def show_svg(self, widget, pixmap, caption):
        self._img.setPixmap(pixmap)
        if caption:
            self._cap.setText(caption)
            self._cap.setMaximumWidth(pixmap.width())
            self._cap.show()
        else:
            self._cap.hide()
        self.adjustSize()
        gp  = widget.mapToGlobal(QtCore.QPoint(widget.width() + 10, 0))
        scr = QtWidgets.QApplication.desktop().availableGeometry(widget)
        if gp.x() + self.width() > scr.right():
            gp = widget.mapToGlobal(QtCore.QPoint(0, widget.height() + 6))
        self.move(gp)
        self.show()
        self.raise_()

    def eventFilter(self, obj, event):
        t = event.type()
        if t == QtCore.QEvent.Enter:
            pm  = obj.property("_svgtip_pm")
            cap = obj.property("_svgtip_cap") or ""
            if pm:
                self.show_svg(obj, pm, cap)
        elif t in (QtCore.QEvent.Leave, QtCore.QEvent.Hide,
                   QtCore.QEvent.WindowDeactivate):
            self.hide()
        elif t == QtCore.QEvent.ToolTip:
            if obj.property("_svgtip_pm"):
                return True          # suppress Qt's text tooltip
        return False


def _attach_svg_tip(widget, svg_str, w, h, caption=""):
    """Render svg_str at 2× DPI and attach as a hover popup to widget."""
    try:
        from PySide2.QtSvg import QSvgRenderer
        from PySide2.QtGui import QImage, QPainter, QPixmap
        from PySide2.QtCore import QByteArray
    except ImportError:
        return
    renderer = QSvgRenderer(QByteArray(svg_str.encode("utf-8")))
    img = QImage(w * 2, h * 2, QImage.Format_ARGB32)
    img.fill(0xFFFFFFFF)
    p = QPainter(img)
    renderer.render(p)
    p.end()
    pm = QPixmap.fromImage(img)
    pm.setDevicePixelRatio(2.0)
    widget.setProperty("_svgtip_pm",  pm)
    widget.setProperty("_svgtip_cap", caption)
    widget.installEventFilter(_SvgTip.get())


# ── dialog ────────────────────────────────────────────────────────────────────

class TrackAssemblyDialog(QtWidgets.QDialog):

    def __init__(self, base_obj):
        super().__init__(FreeCADGui.getMainWindow())
        self.base_obj    = base_obj
        self.left_joint  = None
        self.right_joint = None
        self.setWindowTitle("Track Assembly Builder  v1")
        self.setWindowFlags(QtCore.Qt.Window | QtCore.Qt.WindowStaysOnTopHint)
        self._build_ui()
        self._update_computed()
        self._validate()

    # ── UI ────────────────────────────────────────────────────────────────────

    def _build_ui(self):
        root = QtWidgets.QVBoxLayout(self)
        root.setSpacing(8)

        # selected link
        obj_grp = QtWidgets.QGroupBox("Track link element")
        ol = QtWidgets.QHBoxLayout(obj_grp)
        ol.addWidget(QtWidgets.QLabel(
            "<b>{}</b>".format(self.base_obj.Label if self.base_obj else "none")
        ))
        root.addWidget(obj_grp)

        root.addWidget(self._banner(
            "<b>How to pick a joint:</b><br>"
            "① Click a circular hole <b>edge</b> in the 3-D view  (turns orange)<br>"
            "② Click the matching <b>Pick</b> button below"
        ))

        # ── joint pickers ─────────────────────────────────────────────────────
        joints_grp = QtWidgets.QGroupBox("Joint connection points")
        jv = QtWidgets.QVBoxLayout(joints_grp)
        row = _diagram_row(_SVG_LINK, 300, 88)
        if row:
            jv.addLayout(row)
        jg = QtWidgets.QGridLayout()
        jg.setColumnStretch(1, 1)

        self.left_icon   = QtWidgets.QLabel("○"); self.left_icon.setFixedWidth(20)
        self.left_coords = QtWidgets.QLabel("<i>not picked</i>")
        self.btn_left    = QtWidgets.QPushButton("⬅  Pick Left Joint")
        self.btn_left.setToolTip("① Click hole edge in 3-D view  ② click here")
        _attach_svg_tip(self.btn_left, _SVG_LINK, 300, 88,
                        "① Click the circular hole edge in the 3-D view\n"
                        "② Click this button to record it\n"
                        "Pitch = distance between left and right joint centres")
        self.btn_left.clicked.connect(self._on_pick_left)

        self.right_icon   = QtWidgets.QLabel("○"); self.right_icon.setFixedWidth(20)
        self.right_coords = QtWidgets.QLabel("<i>not picked</i>")
        self.btn_right    = QtWidgets.QPushButton("Pick Right Joint  ➡")
        self.btn_right.setToolTip("① Click hole edge in 3-D view  ② click here")
        _attach_svg_tip(self.btn_right, _SVG_LINK, 300, 88,
                        "① Click the circular hole edge in the 3-D view\n"
                        "② Click this button to record it\n"
                        "Pitch = distance between left and right joint centres")
        self.btn_right.clicked.connect(self._on_pick_right)

        jg.addWidget(self.left_icon,    0, 0)
        jg.addWidget(self.left_coords,  0, 1)
        jg.addWidget(self.btn_left,     0, 2)
        jg.addWidget(self.right_icon,   1, 0)
        jg.addWidget(self.right_coords, 1, 1)
        jg.addWidget(self.btn_right,    1, 2)
        jv.addLayout(jg)
        root.addWidget(joints_grp)

        root.addWidget(self._hsep())

        # ── loop direction ─────────────────────────────────────────────────────
        dir_grp = QtWidgets.QGroupBox("Loop direction")
        dir_lay = QtWidgets.QHBoxLayout(dir_grp)
        self.radio_up   = QtWidgets.QRadioButton("↑  Up   (CCW)")
        self.radio_down = QtWidgets.QRadioButton("↓  Down  (CW)")
        self.radio_up.setChecked(True)
        dir_tip = (
            "Up (CCW):   curved sections extend ABOVE the straight runs\n"
            "\n"
            "        ╭──── arc ────╮\n"
            "        │             │\n"
            "════════╯             ╰════════\n"
            "\n"
            "Down (CW):  curved sections extend BELOW the straight runs\n"
            "\n"
            "════════╮             ╭════════\n"
            "        │             │\n"
            "        ╰──── arc ────╯"
        )
        self.radio_up.setToolTip(dir_tip)
        self.radio_down.setToolTip(dir_tip)
        self.radio_up.toggled.connect(self._update_dir_diagram)
        dir_lay.addWidget(self.radio_up)
        dir_lay.addWidget(self.radio_down)
        self.dir_diagram = QtWidgets.QLabel()
        self.dir_diagram.setAlignment(QtCore.Qt.AlignCenter)
        self.dir_diagram.setStyleSheet(
            "font-family:monospace; font-size:11px; color:#333;"
            "background:#f5f5f5; border:1px solid #ccc; border-radius:4px; padding:4px;"
        )
        self._update_dir_diagram()
        dir_lay.addWidget(self.dir_diagram)
        root.addWidget(dir_grp)

        root.addWidget(self._hsep())

        # ── wheel parameters ───────────────────────────────────────────────────
        wheel_grp = QtWidgets.QGroupBox("Wheel parameters")
        wv = QtWidgets.QVBoxLayout(wheel_grp)
        row = _diagram_row(_SVG_WHEEL, 300, 132)
        if row:
            wv.addLayout(row)
        wf = QtWidgets.QFormLayout()
        wv.addLayout(wf)

        self.spin_D = QtWidgets.QDoubleSpinBox()
        self.spin_D.setRange(1.0, 99999.0); self.spin_D.setDecimals(3)
        self.spin_D.setSuffix(" mm"); self.spin_D.setValue(80.0)
        self.spin_D.setToolTip("Outer wheel diameter  (drives N per arc)")
        _attach_svg_tip(self.spin_D, _SVG_WHEEL, 300, 132,
                        "Outer diameter D — chain rides on this edge\n"
                        "Larger D → fewer links per arc → gentler curve")
        self.spin_D.valueChanged.connect(self._on_param_changed)
        wf.addRow("Wheel diameter D:", self.spin_D)

        self.spin_W = QtWidgets.QDoubleSpinBox()
        self.spin_W.setRange(0.1, 9999.0); self.spin_W.setDecimals(3)
        self.spin_W.setSuffix(" mm"); self.spin_W.setValue(20.0)
        self.spin_W.setToolTip("Wheel width along axle axis  (≥ chain inner width)")
        _attach_svg_tip(self.spin_W, _SVG_WHEEL, 300, 132,
                        "Width W — should be ≥ chain inner width")
        self.spin_W.valueChanged.connect(self._on_param_changed)
        wf.addRow("Wheel width W:", self.spin_W)

        self.spin_hub = QtWidgets.QDoubleSpinBox()
        self.spin_hub.setRange(0.0, 9999.0); self.spin_hub.setDecimals(3)
        self.spin_hub.setSuffix(" mm"); self.spin_hub.setValue(10.0)
        self.spin_hub.setToolTip("Hub bore diameter  (0 = solid, must be < D)")
        _attach_svg_tip(self.spin_hub, _SVG_WHEEL, 300, 132,
                        "Hub bore ⌀ — central axle hole\n0 = solid wheel  ·  must be < D")
        self.spin_hub.valueChanged.connect(self._on_param_changed)
        wf.addRow("Hub bore ⌀:", self.spin_hub)
        wf.addRow("", self._hint("0 = solid wheel  ·  must be < D"))

        self.spin_H = QtWidgets.QDoubleSpinBox()
        self.spin_H.setRange(0.1, 9999.0); self.spin_H.setDecimals(3)
        self.spin_H.setSuffix(" mm"); self.spin_H.setValue(8.0)
        self.spin_H.setToolTip("Link body height  (sets polygon face depth)")
        _attach_svg_tip(self.spin_H, _SVG_H, 280, 90,
                        "Link body height H\n"
                        "Polygon apothem = R·cos(π/2n) − H/2\n"
                        "so the link inner face sits flush on each polygon face")
        self.spin_H.valueChanged.connect(self._on_param_changed)
        wf.addRow("Link body height H:", self.spin_H)
        wf.addRow("", self._hint("thickness of one link body  ·  sets polygon face depth"))

        self.check_sym = QtWidgets.QCheckBox("Symmetric  (centred on Z = 0)")
        self.check_sym.setChecked(True)
        self.check_sym.setToolTip("Symmetric: centred on Z=0 (W/2 each side)  ·  Unchecked: starts at Z=0 extends +W")
        _attach_svg_tip(self.check_sym, _SVG_SYM, 300, 110,
                        "Checked: wheel centred on Z=0 (W/2 each side)\n"
                        "Unchecked: wheel starts at Z=0, extends W in +Z")
        wf.addRow("", self.check_sym)

        root.addWidget(wheel_grp)

        root.addWidget(self._hsep())

        # ── chain parameters ───────────────────────────────────────────────────
        chain_grp = QtWidgets.QGroupBox("Chain parameters")
        cf = QtWidgets.QFormLayout(chain_grp)

        self.spin_dist = QtWidgets.QDoubleSpinBox()
        self.spin_dist.setRange(0.0, 999999.0); self.spin_dist.setDecimals(2)
        self.spin_dist.setSuffix(" mm"); self.spin_dist.setValue(100.0)
        self.spin_dist.setToolTip("Minimum centre-to-centre wheel distance  (0 = pure circle)")
        _attach_svg_tip(self.spin_dist, _SVG_DIST, 300, 90,
                        "Minimum centre-to-centre wheel distance\n"
                        "Rounded up to whole links  ·  0 = pure circle")
        self.spin_dist.valueChanged.connect(self._on_param_changed)
        cf.addRow("Min wheel distance:", self.spin_dist)
        cf.addRow("", self._hint("centre-to-centre  ·  0 = pure circle"))

        root.addWidget(chain_grp)

        root.addWidget(self._hsep())

        # ── computed panel ─────────────────────────────────────────────────────
        comp_grp = QtWidgets.QGroupBox("Computed")
        comp_grp.setStyleSheet("QGroupBox { background:#f0f4f8; border-radius:4px; }")
        cfl = QtWidgets.QFormLayout(comp_grp)

        self.lbl_pitch      = QtWidgets.QLabel("—")
        self.lbl_n_arc      = QtWidgets.QLabel("—")
        self.lbl_n_straight = QtWidgets.QLabel("—")
        self.lbl_n_total    = QtWidgets.QLabel("—")
        self.lbl_radius     = QtWidgets.QLabel("—")
        self.lbl_apothem    = QtWidgets.QLabel("—")
        self.lbl_straight   = QtWidgets.QLabel("—")

        cfl.addRow("Pitch:",                 self.lbl_pitch)
        cfl.addRow("N per arc:",             self.lbl_n_arc)
        cfl.addRow("N straight per side:",   self.lbl_n_straight)
        cfl.addRow("Total links:",           self.lbl_n_total)
        cfl.addRow("Arc radius:",            self.lbl_radius)
        cfl.addRow("Polygon face depth:",    self.lbl_apothem)
        cfl.addRow("Actual wheel distance:", self.lbl_straight)

        root.addWidget(comp_grp)

        root.addWidget(self._hsep())

        # ── what to generate ───────────────────────────────────────────────────
        gen_grp = QtWidgets.QGroupBox("Generate")
        gh = QtWidgets.QHBoxLayout(gen_grp)
        self.check_chain       = QtWidgets.QCheckBox("Chain")
        self.check_wheel_left  = QtWidgets.QCheckBox("Left wheel")
        self.check_wheel_right = QtWidgets.QCheckBox("Right wheel")
        self.check_chain.setToolTip(
            "Generate the chain compound:\n"
            "N copies of the selected link body placed around the oval.")
        self.check_wheel_left.setToolTip(
            "Generate the left wheel cylinder.\n"
            "Placed at the left arc centre.")
        self.check_wheel_right.setToolTip(
            "Generate the right wheel cylinder.\n"
            "Placed at the right arc centre.")
        for cb in (self.check_chain, self.check_wheel_left, self.check_wheel_right):
            cb.setChecked(True)
            gh.addWidget(cb)
        gh.addStretch()
        root.addWidget(gen_grp)

        # ── buttons ────────────────────────────────────────────────────────────
        btn_row = QtWidgets.QHBoxLayout()
        self.gen_btn = QtWidgets.QPushButton("Generate Assembly")
        self.gen_btn.setDefault(True)
        self.gen_btn.setEnabled(False)
        self.gen_btn.clicked.connect(self._on_generate)
        cancel_btn = QtWidgets.QPushButton("Cancel")
        cancel_btn.clicked.connect(self.reject)
        btn_row.addStretch()
        btn_row.addWidget(cancel_btn)
        btn_row.addWidget(self.gen_btn)
        root.addLayout(btn_row)

        self.setMinimumWidth(480)

    # ── helpers ───────────────────────────────────────────────────────────────

    def _banner(self, html):
        lbl = QtWidgets.QLabel(html)
        lbl.setStyleSheet(
            "background:#fffbe6; border:1px solid #f0c040;"
            "border-radius:4px; padding:6px;")
        lbl.setWordWrap(True)
        return lbl

    def _hint(self, txt):
        lbl = QtWidgets.QLabel(txt)
        lbl.setStyleSheet("color:gray; font-size:10px;")
        lbl.setWordWrap(True)
        return lbl

    def _hsep(self):
        sep = QtWidgets.QFrame()
        sep.setFrameShape(QtWidgets.QFrame.HLine)
        sep.setFrameShadow(QtWidgets.QFrame.Sunken)
        return sep

    def _update_dir_diagram(self):
        if self.radio_up.isChecked():
            self.dir_diagram.setText(
                "  ╭──────────────╮\n"
                "  │  ↑  UP loop  │\n"
                "  ╰──────────────╯\n"
                "  ══════════════  "
            )
        else:
            self.dir_diagram.setText(
                "  ══════════════  \n"
                "  ╭─────────────╮\n"
                "  │ ↓ DOWN loop │\n"
                "  ╰─────────────╯"
            )

    # ── joint picking ─────────────────────────────────────────────────────────

    def _read_circle(self):
        for item in FreeCADGui.Selection.getSelectionEx():
            for sub in item.SubObjects:
                if hasattr(sub, "Curve") and hasattr(sub.Curve, "Center"):
                    c = sub.Curve.Center
                    return FreeCAD.Vector(c.x, c.y, c.z)
        return None

    def _fmt(self, v):
        return "({:.2f},  {:.2f},  {:.2f})".format(v.x, v.y, v.z)

    def _warn_no_circle(self):
        QtWidgets.QMessageBox.warning(
            self, "No circular edge selected",
            "No circular edge found in the current selection.\n\n"
            "• Click directly on the rim of the hole (not the flat face)\n"
            "• The edge turns orange when selected\n"
            "• Then click the Pick button"
        )

    def _on_pick_left(self):
        c = self._read_circle()
        if c is None:
            self._warn_no_circle(); return
        self.left_joint = c
        self.left_icon.setText("✅")
        self.left_coords.setText(self._fmt(c))
        self._on_param_changed()

    def _on_pick_right(self):
        c = self._read_circle()
        if c is None:
            self._warn_no_circle(); return
        self.right_joint = c
        self.right_icon.setText("✅")
        self.right_coords.setText(self._fmt(c))
        self._on_param_changed()

    def _on_param_changed(self, _=None):
        self._update_computed()
        self._validate()

    # ── math ──────────────────────────────────────────────────────────────────

    def _pitch(self):
        j1, j2 = self.left_joint, self.right_joint
        if j1 is None or j2 is None:
            return None
        return math.sqrt((j2.x-j1.x)**2 + (j2.y-j1.y)**2 + (j2.z-j1.z)**2)

    def _n_per_arc(self, pitch, D):
        arg = pitch / D
        if arg >= 1.0:
            return None
        return max(2, round(math.pi / (2.0 * math.asin(arg))))

    # ── computed labels ───────────────────────────────────────────────────────

    def _n_straight(self, p):
        dist = self.spin_dist.value()
        if dist <= 0.0 or p <= 0.0:
            return 0
        return math.ceil(dist / p)

    def _update_computed(self):
        p = self._pitch()
        if p is None:
            for lbl in (self.lbl_pitch, self.lbl_n_arc, self.lbl_n_straight,
                        self.lbl_n_total, self.lbl_radius, self.lbl_apothem,
                        self.lbl_straight):
                lbl.setText("—")
            return

        D     = self.spin_D.value()
        h_seg = self.spin_H.value() / 2.0
        Ns    = self._n_straight(p)

        self.lbl_pitch.setText("<b>{:.4f} mm</b>".format(p))

        n = self._n_per_arc(p, D)
        if n is None:
            msg = "<i style='color:red'>diameter too small for this pitch</i>"
            for lbl in (self.lbl_n_arc, self.lbl_n_straight, self.lbl_n_total,
                        self.lbl_radius, self.lbl_apothem, self.lbl_straight):
                lbl.setText(msg)
            return

        N          = 2 * n + 2 * Ns
        radius     = p / (2.0 * math.sin(math.pi / (2.0 * n)))
        half_angle = math.pi / (2 * n)
        apothem    = radius * math.cos(half_angle) - h_seg
        s_len      = Ns * p

        self.lbl_n_arc.setText("<b>{}</b>  links per arc".format(n))
        self.lbl_n_straight.setText("<b>{}</b>  links per side".format(Ns))
        self.lbl_n_total.setText("<b>{}</b>  links".format(N))
        self.lbl_radius.setText(
            "<b>{:.3f} mm</b>  →  {}-gon wheel".format(radius, 2 * n))
        self.lbl_apothem.setText(
            "<b>{:.3f} mm</b>  (R·cos(π/2n) − H/2)".format(apothem))
        self.lbl_straight.setText(
            "<b>{:.3f} mm</b>  ({} × pitch)".format(s_len, Ns))

    # ── validation ────────────────────────────────────────────────────────────

    def _validate(self):
        p = self._pitch()
        ok = True
        if p is None:
            ok = False
        else:
            D   = self.spin_D.value()
            hub = self.spin_hub.value()
            if self._n_per_arc(p, D) is None:
                ok = False
            elif hub >= D:
                ok = False
        self.gen_btn.setEnabled(ok)
        return ok

    # ── wheel body (PartDesign) ───────────────────────────────────────────────

    def _make_wheel_body(self, label, n, pitch, W, hub_bore, h_seg, symmetric, cx, cy):
        """Create a PartDesign::Body with a sketch + pad so the user can keep
        editing the wheel in the normal parametric workflow.

        Profile: regular 2n-gon with optional bore circle in the same sketch.
        Sketch placed at (cx, cy, z_offset) facing +Z.
        symmetric=True  → z_offset = −W/2  (wheel centred on Z=0)
        symmetric=False → z_offset =  0    (wheel starts at Z=0, extends +W)
        """
        doc = FreeCAD.ActiveDocument

        R          = pitch / (2.0 * math.sin(math.pi / (2.0 * n)))
        Rb         = hub_bore / 2.0
        n_sides    = 2 * n
        half_angle = math.pi / n_sides
        link_mid_r = R * math.cos(half_angle)
        apothem    = link_mid_r - h_seg
        R_poly     = apothem / math.cos(half_angle)
        z_offset   = -W / 2.0 if symmetric else 0.0

        body   = doc.addObject("PartDesign::Body",       label)
        sketch = doc.addObject("Sketcher::SketchObject", label + "_Sketch")
        body.addObject(sketch)

        sketch.Placement = FreeCAD.Placement(
            FreeCAD.Vector(cx, cy, z_offset),
            FreeCAD.Rotation()          # XY plane, +Z normal
        )

        # polygon outline (local coords — origin = wheel centre)
        for i in range(n_sides):
            a0 = math.radians(-90.0 + i       * 360.0 / n_sides)
            a1 = math.radians(-90.0 + (i + 1) * 360.0 / n_sides)
            sketch.addGeometry(Part.LineSegment(
                FreeCAD.Vector(R_poly * math.cos(a0), R_poly * math.sin(a0), 0),
                FreeCAD.Vector(R_poly * math.cos(a1), R_poly * math.sin(a1), 0)
            ))

        # bore circle (inner loop → Pad treats it as a through-hole)
        if Rb > 0.001:
            sketch.addGeometry(
                Part.Circle(FreeCAD.Vector(0, 0, 0), FreeCAD.Vector(0, 0, 1), Rb)
            )

        pad = doc.addObject("PartDesign::Pad", label + "_Pad")
        body.addObject(pad)
        pad.Profile = sketch
        pad.Length  = W
        body.Tip    = pad

        return body

    # ── generate ──────────────────────────────────────────────────────────────

    def _on_generate(self):
        if not self._validate():
            return

        j1  = self.left_joint
        j2  = self.right_joint
        p   = self._pitch()
        D   = self.spin_D.value()
        W   = self.spin_W.value()
        hub   = self.spin_hub.value()
        h_seg = self.spin_H.value() / 2.0
        Ns    = self._n_straight(p)
        Ddir = +1.0 if self.radio_up.isChecked() else -1.0

        n       = self._n_per_arc(p, D)
        N       = 2 * n + 2 * Ns
        radius  = p / (2.0 * math.sin(math.pi / (2.0 * n)))
        half_sl = Ns * p / 2.0

        cx    = (j1.x + j2.x) / 2.0
        cy    = (j1.y + j2.y) / 2.0
        cz    = (j1.z + j2.z) / 2.0
        e_ang = math.degrees(math.atan2(j2.y - j1.y, j2.x - j1.x))

        doc     = FreeCAD.ActiveDocument
        created = []

        # ── chain ─────────────────────────────────────────────────────────────
        if self.check_chain.isChecked():
            base_shape = self.base_obj.Shape

            def _mat(tx, ty_raw, chain_deg_raw):
                ty        = Ddir * ty_raw
                chain_deg = Ddir * chain_deg_raw
                a  = math.radians(chain_deg - e_ang)
                ca, sa = math.cos(a), math.sin(a)
                m = FreeCAD.Matrix()
                m.A11 = ca;  m.A12 = -sa; m.A13 = 0; m.A14 = tx - ca*cx + sa*cy
                m.A21 = sa;  m.A22 =  ca; m.A23 = 0; m.A24 = ty - sa*cx - ca*cy
                m.A31 =  0;  m.A32 =   0; m.A33 = 1; m.A34 = 0
                m.A41 =  0;  m.A42 =   0; m.A43 = 0; m.A44 = 1
                return m

            shapes = []
            aS = 180.0 / n

            def _add(tx, ty, deg):
                shapes.append(base_shape.transformGeometry(_mat(tx, ty, deg)))

            # bottom straight  →
            for i in range(Ns):
                _add(-half_sl + p/2 + i*p, -radius, 0.0)

            # right arc  (−90° → +90°)
            for i in range(n):
                phi0 = math.radians(-90.0 +  i      * aS)
                phi1 = math.radians(-90.0 + (i + 1) * aS)
                px0 = half_sl + radius * math.cos(phi0); py0 = radius * math.sin(phi0)
                px1 = half_sl + radius * math.cos(phi1); py1 = radius * math.sin(phi1)
                _add((px0+px1)/2, (py0+py1)/2,
                     math.degrees(math.atan2(py1-py0, px1-px0)))

            # top straight  ←
            for i in range(Ns):
                _add(half_sl - p/2 - i*p, radius, 180.0)

            # left arc  (+90° → +270°)
            for i in range(n):
                phi0 = math.radians(90.0 +  i      * aS)
                phi1 = math.radians(90.0 + (i + 1) * aS)
                px0 = -half_sl + radius * math.cos(phi0); py0 = radius * math.sin(phi0)
                px1 = -half_sl + radius * math.cos(phi1); py1 = radius * math.sin(phi1)
                _add((px0+px1)/2, (py0+py1)/2,
                     math.degrees(math.atan2(py1-py0, px1-px0)))

            compound = Part.makeCompound(shapes)
            feat = doc.addObject("Part::Feature", "TrackChain")
            feat.Shape = compound
            feat.Label = "TrackChain_{}links_{}".format(
                N, "up" if Ddir > 0 else "down")
            created.append(feat.Label)

        # ── wheels ────────────────────────────────────────────────────────────
        sym = self.check_sym.isChecked()
        for side, wx in (("Left", -half_sl), ("Right", half_sl)):
            cb = self.check_wheel_left if side == "Left" else self.check_wheel_right
            if not cb.isChecked():
                continue
            label = "Wheel_{}_{}-gon".format(side, 2 * n)
            try:
                self._make_wheel_body(label, n, p, W, hub, h_seg, sym, wx, 0.0)
            except Exception as e:
                QtWidgets.QMessageBox.critical(self, "Wheel Error", str(e))
                return
            created.append(label)

        doc.recompute()

        try:
            FreeCADGui.ActiveDocument.activeView().viewTop()
            FreeCADGui.SendMsgToActiveView("ViewFit")
        except Exception:
            pass

        self.accept()

        QtWidgets.QMessageBox.information(
            None, "Track Assembly  –  Done",
            "Assembly created!\n\n"
            "  Pitch             : {:.4f} mm\n"
            "  N per arc         : {}\n"
            "  Total links       : {}\n"
            "  Straight / side   : {} links  (actual {:.2f} mm)\n"
            "  Wheel shape       : {}-gon  (circumradius {:.3f} mm)\n"
            "  Wheel width       : {:.3f} mm\n"
            "  Direction         : {}\n\n"
            "Objects created:\n{}".format(
                p, n, N, Ns, Ns*p, 2*n, radius, W,
                "Up (CCW)" if Ddir > 0 else "Down (CW)",
                "\n".join("  • " + lbl for lbl in created)
            )
        )


# ── entry point ───────────────────────────────────────────────────────────────

def run():
    try:
        from PySide2 import QtWidgets, QtCore
    except ImportError:
        from PySide import QtGui as QtWidgets, QtCore

    if not FreeCAD.ActiveDocument:
        QtWidgets.QMessageBox.warning(
            None, "Track Assembly",
            "No active document.\nCreate or open a FreeCAD document first."
        )
        return

    sel = FreeCADGui.Selection.getSelection()
    if not sel:
        QtWidgets.QMessageBox.warning(
            None, "Track Assembly",
            "Select the track-link body in the 3-D view first,\nthen run the macro."
        )
        return

    dlg = TrackAssemblyDialog(sel[0])
    dlg.show()

    loop = QtCore.QEventLoop()
    dlg.finished.connect(loop.quit)
    loop.exec_()


run()
