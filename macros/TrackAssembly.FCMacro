def _svg_label(svg_str, w, h):
    """Render SVG string to a QLabel via QSvgRenderer. Returns None if unavailable."""
    try:
        from PySide2.QtSvg import QSvgRenderer
        from PySide2.QtGui import QImage, QPainter, QPixmap
        from PySide2.QtCore import QByteArray
    except ImportError:
        return None
    renderer = QSvgRenderer(QByteArray(svg_str.encode("utf-8")))
    img = QImage(w, h, QImage.Format_ARGB32)
    img.fill(0xFFFFFFFF)
    p = QPainter(img)
    renderer.render(p)
    p.end()
    lbl = QtWidgets.QLabel()
    lbl.setPixmap(QPixmap.fromImage(img))
    lbl.setAlignment(QtCore.Qt.AlignCenter)
    return lbl


def _diagram_row(svg_str, w, h):
    """Return a QHBoxLayout with the diagram centred, or None."""
    lbl = _svg_label(svg_str, w, h)
    if lbl is None:
        return None
    row = QtWidgets.QHBoxLayout()
    row.addStretch(); row.addWidget(lbl); row.addStretch()
    return row


